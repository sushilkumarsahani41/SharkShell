# ─── SharkShell Docker Config ───
# Copy this to .env and customize, or run: ./init.sh

# ── Database (internal PostgreSQL) ──
DB_HOST=postgres
DB_PORT=5432
DB_USER=sharkshell
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=sharkshell

# ── External Database ──
# Set DB_EXTERNAL=true and fill in your own DB connection:
# DB_EXTERNAL=true
# DB_HOST=your-db-host.com
# DB_PORT=5432
# DB_USER=your_user
# DB_PASSWORD=your_password
# DB_NAME=your_database

# ── Security ──
# 64-char hex string (32 bytes) for AES-256-GCM
ENCRYPTION_KEY=
# JWT: uses RSA key files by default (auto-generated in Docker)
# For simple deployments, you can use a string secret instead:
# JWT_SECRET=change-me-to-a-strong-secret

# ── App ──
PORT=3002
COMPOSE_PORT=8080
